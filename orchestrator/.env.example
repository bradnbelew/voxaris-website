# ──────────────────────────────────────────────
# Voxaris Orchestrator — Environment Variables
# Copy to .env.local and fill in real values
# ──────────────────────────────────────────────

# ── Brain Mode ──
# "tavus"  = Raven-1 handles all reasoning, thin tool executor (DEFAULT, faster)
# "claude" = Claude ReAct loop with full tool set (fallback, more capable)
BRAIN_MODE=tavus

# ── Tavus CVI (Video Avatar) ──
TAVUS_API_KEY=
TAVUS_PERSONA_ID=
TAVUS_WEBHOOK_SECRET=

# ── Rover (DOM Automation) ──
ROVER_API_KEY=
ROVER_API_BASE=https://api.rtrvr.ai/v1

# ── Anthropic (Only needed when BRAIN_MODE=claude) ──
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Vercel Postgres (Drizzle ORM) ──
DATABASE_URL=postgres://...
DATABASE_URL_UNPOOLED=postgres://...

# ── Vercel KV (Upstash Redis — Sessions) ──
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=AX...

# ── Clerk Auth (Multi-Tenant Dashboard) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/dashboard/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/dashboard/sign-up

# ── App Config ──
NEXT_PUBLIC_APP_URL=https://orchestrator.voxaris.io
EMBED_ALLOWED_ORIGINS=*
SESSION_TTL_SECONDS=1800
MAX_ACTIONS_PER_SESSION=50
RATE_LIMIT_RPM=60
