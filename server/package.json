{
  "name": "voxaris-server",
  "version": "1.1.0",
  "description": "Backend for V-Suite SaaS (Express + TypeScript)",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "worker": "node dist/workers/worker.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/worker.ts",
    "build": "tsc -p .",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@retellai/n8n-nodes-retellai": "^0.2.3",
    "@sentry/node": "^10.38.0",
    "@supabase/supabase-js": "^2.91.0",
    "@types/ws": "^8.18.1",
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.2",
    "bullmq": "^5.67.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "openai": "^6.16.0",
    "rate-limit-redis": "^4.2.0",
    "resend": "^6.9.1",
    "retell-sdk": "^4.66.0",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.3",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
