# ============================================
# VOXARIS BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git!
# ============================================

# === APP CONFIG ===
NODE_ENV=development
PORT=3000
WORKER_PORT=3001

# ============================================
# TIER 1: PLATFORM API KEYS (Global Voxaris)
# ============================================
# These are YOUR Voxaris account keys.
# Each dealer gets resources (personas, agents) under your account.

# Tavus.io - Video AI
TAVUS_API_KEY=tvs_xxxxxxxxxxxx
TAVUS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
DEFAULT_TAVUS_REPLICA_ID=rfe12d8b9597

# Retell AI - Voice AI
RETELL_API_KEY=key_xxxxxxxxxxxx
RETELL_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
RETELL_LLM_ID=llm_xxxxxxxxxxxx

# OpenAI - For SMS bot and analysis
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Anthropic - For lead scoring (optional, if using Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Resend - Email delivery
RESEND_API_KEY=re_xxxxxxxxxxxx

# ============================================
# TIER 2: INFRASTRUCTURE
# ============================================

# Supabase (Database)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx

# Upstash Redis (Queue + Cache)
UPSTASH_REDIS_URL=redis://default:xxxxxxxxxxxx@xxxxxxxxxxxx.upstash.io:6379

# ============================================
# TIER 3: SECURITY
# ============================================

# Master encryption key for dealer credentials
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=64_character_hex_string_here

# Admin API key for internal tools (Cowork, dashboards)
# Generate with: openssl rand -hex 32
# Used as: Authorization: Bearer YOUR_KEY
VOXARIS_ADMIN_KEY=64_character_hex_string_here

# Base URL for webhooks (used when creating Tavus/Retell integrations)
API_BASE_URL=https://your-api.onrender.com

# ============================================
# TIER 4: LEGACY GHL (Fallback)
# ============================================
# Used when dealer_integrations table doesn't exist yet.
# Remove these after migrating to per-dealer credentials.

GHL_ACCESS_TOKEN=eyJxxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxx

# ============================================
# MONITORING (Optional)
# ============================================

# Grafana Loki for centralized logging
GRAFANA_LOKI_HOST=https://logs-prod-us-central1.grafana.net
GRAFANA_LOKI_USER=123456
GRAFANA_LOKI_PASSWORD=xxxxxxxxxxxx

# Sentry for error tracking (Tier 2)
SENTRY_DSN=https://xxxxxxxxxxxx@sentry.io/xxxxxxxxxxxx

# ============================================
# NOTES
# ============================================
#
# API KEY ARCHITECTURE:
# - Platform keys (Tavus, Retell, etc.): Global, stored in .env
# - Per-dealer keys (GHL): Encrypted, stored in dealer_integrations table
#
# WEBHOOK SECRETS:
# - Configure in Tavus/Retell dashboard to match these values
# - Used for signature validation to prevent fake webhooks
#
# ENCRYPTION_KEY:
# - Used to encrypt dealer GHL credentials in database
# - Rotate quarterly: re-encrypt all credentials with new key
# - Keep old key for 30 days for rollback
#
