# Environment Variables for Voxaris Dashboard
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_URL=https://api.voxaris.io/v1
VITE_WS_URL=wss://api.voxaris.io

# Optional: Default location for testing
VITE_DEFAULT_LOCATION_ID=

# Feature Flags
VITE_ENABLE_REALTIME=true
VITE_ENABLE_EXPORTS=true
