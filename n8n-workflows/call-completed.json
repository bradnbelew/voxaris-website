{
  "name": "V-Suite Voice Analytics",
  "nodes": [
    {
      "parameters": {
        "path": "call-completed",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Retell Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 100, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://hill-nissan-backend.onrender.com/api/analytics/ingest",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "source",
              "value": "retell"
            },
            {
              "name": "call_id",
              "value": "={{$json.body.call_id}}"
            },
            {
              "name": "data",
              "value": "={{$json.body.call_analysis}}"
            }
          ]
        }
      },
      "name": "Push to V-Suite",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [ 300, 300 ]
    }
  ],
  "connections": {
    "Retell Webhook": { "main": [ [ { "node": "Push to V-Suite", "type": "main", "index": 0 } ] ] }
  }
}
